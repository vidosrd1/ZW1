#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: bin/hatchbox [command] [options]

Commands:
  (none)        Open a plain SSH session
  console       Start a Rails console on the server
  current       Open a shell in the current release directory
  logs <name>   Tail systemd journal logs for <SSH_APP_NAME>-<name>

Options:
  --help        Show this help message

Environment variables (set in .env):
  SSH_APP_NAME          (required) App path on the server

Connection (first takes precedence, one is required):
  Option 1: SSH_HOST_ALIAS   SSH config alias (matches a host in ~/.ssh/config)
  Option 2: SSH_HOST          Server hostname (connects as deploy@SSH_HOST)

Examples:
  bin/hatchbox                        # SSH using .env config
  bin/hatchbox console                # Rails console
  bin/hatchbox logs server            # Tail server logs
  bin/hatchbox logs solid_queue       # Tail queue worker logs
USAGE
  exit 0
}

# Load .env
if [ -f .env ]; then
  set -a
  # shellcheck source=.env
  source .env
  set +a
fi

: "${SSH_APP_NAME:?❌ Error: SSH_APP_NAME is not set in .env}"

COMMAND=""
ARG=""

# ----------------------------
# Parse arguments
# ----------------------------
if [[ $# -gt 0 ]]; then
  case "$1" in
    --help|-h)
      usage
      ;;
    console|current|logs)
      COMMAND="$1"
      shift
      ;;
    *)
      echo "❌ Error: unknown command '$1'"
      echo "Run 'bin/hatchbox --help' for usage."
      exit 1
      ;;
  esac
fi

# Capture remaining argument (used by logs command)
if [[ $# -gt 0 ]]; then
  ARG="$1"
  shift
fi

if [[ $# -gt 0 ]]; then
  echo "❌ Error: unexpected argument '$1'"
  echo "Run 'bin/hatchbox --help' for usage."
  exit 1
fi

# ----------------------------
# Determine SSH target
# ----------------------------
if [[ -n "${SSH_HOST_ALIAS:-}" ]]; then
  SSH_TARGET="$SSH_HOST_ALIAS"
elif [[ -n "${SSH_HOST:-}" ]]; then
  SSH_TARGET="deploy@$SSH_HOST"
else
  echo ""
  echo "❌ Error: set SSH_HOST_ALIAS or SSH_HOST in .env"
  echo ""
  exit 1
fi

echo ""
echo "🌐 Connecting to $SSH_TARGET"

# ----------------------------
# Execute commands
# ----------------------------
case "$COMMAND" in
  console)
    echo "🟢 Booting Rails console in $SSH_APP_NAME/current..."
    echo ""
    ssh -t "$SSH_TARGET" "cd \$HOME/$SSH_APP_NAME/current && bundle exec rails c"
    ;;

  current)
    echo "🟢 Opening shell in $SSH_APP_NAME/current..."
    echo ""
    ssh -t "$SSH_TARGET" "cd \$HOME/$SSH_APP_NAME/current && exec \$SHELL"
    ;;

  logs)
    if [[ -z "$ARG" ]]; then
      echo ""
      echo "❌ Error: logs command requires a process name, e.g. bin/hatchbox logs server"
      echo ""
      exit 1
    fi
    logs_unit="${SSH_APP_NAME}-${ARG}"
    echo ""
    echo "📜 Checking unit $logs_unit..."
    echo ""
    if ! ssh "$SSH_TARGET" "systemctl --user list-units --full --no-legend | grep -q '$logs_unit'"; then
      echo "❌ Error: unit '$logs_unit' not found on $SSH_TARGET"
      echo ""
      exit 1
    fi
    echo "📜 Tailing logs for unit $logs_unit..."
    echo ""
    ssh -t "$SSH_TARGET" "journalctl --user --unit=$logs_unit --follow"
    ;;

  "")
    echo ""
    echo "🔑 Opening default SSH session..."
    echo ""
    ssh "$SSH_TARGET"
    ;;

  *)
    echo ""
    echo "❌ Unknown command: $COMMAND"
    echo ""
    exit 1
    ;;
esac
